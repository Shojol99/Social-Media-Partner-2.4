{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "Represents a customer order for the AI Video Vault",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique order ID" },
        "name": { "type": "string", "description": "Customer name" },
        "email": { "type": "string", "format": "email", "description": "Customer email" },
        "phone": { "type": "string", "description": "Customer phone number" },
        "transactionId": { "type": "string", "description": "bKash Transaction ID" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Current status of the order" },
        "createdAt": { "type": "number", "description": "Timestamp of order creation" },
        "approvedAt": { "type": "number", "description": "Timestamp of order approval" },
        "driveAccess": { "type": "boolean", "description": "Whether Google Drive access was granted" },
        "emailSent": { "type": "boolean", "description": "Whether delivery email was sent" }
      },
      "required": ["id", "name", "email", "phone", "transactionId", "status", "createdAt"]
    }
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of all customer orders"
    }
  }
}
